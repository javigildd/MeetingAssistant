# Path to a Python interpreter that has whisperx + pyannote-audio installed.
# Example: ~/Library/Application Support/whisperx-venv/bin/python
MA_PYTHON=

# OpenAI key — used ONLY for summary, action items, embeddings and chat.
# Audio and raw transcripts NEVER leave your machine.
OPENAI_API_KEY=

# Optional: Hugging Face token. Only needed the first time you run diarization
# so pyannote can download the model. After that it caches.
HUGGINGFACE_TOKEN=

# Whisper model. Defaults to large-v3. Other options: medium, medium.en, small.
MA_WHISPER_MODEL=large-v3

# Compute type for faster-whisper. int8 is fastest on Apple Silicon CPU.
# Options: int8, float16, float32
MA_COMPUTE_TYPE=int8

# Where recordings/transcripts/db live. Defaults to ~/MeetingAssistant.
MA_DATA_DIR=
